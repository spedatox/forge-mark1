# ─────────────────────────────────────────────────────────────────────────────
# The Forge — environment configuration
#
# The Forge assumes its environment (§9.5: fail loud, don't degrade through
# ladders). Set what you need; missing-but-required values crash loudly at
# startup with a clear message rather than silently no-op'ing.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (the Warden's reasoning) — multi-provider, mirrors Mark VI ───────────
# A profile's model is a "provider:model" ref (bare name → Anthropic). Set the
# key for whichever providers your agent profiles use. The demo
# (`python -m forge demo`) runs on a deterministic scripted model and needs NONE.
#   Anthropic → ANTHROPIC_API_KEY  (bare refs, e.g. claude-sonnet-4-6)
#   OpenAI    → OPENAI_API_KEY     (openai:gpt-5.1, openai:gpt-5-mini)
#   Gemini    → GEMINI_API_KEY     (gemini:gemini-2.5-pro, gemini:gemini-2.5-flash)
#   z.ai      → ZAI_API_KEY        (zai:glm-4.6)
#   DeepSeek  → DEEPSEEK_API_KEY   (deepseek:deepseek-v4-pro)
#   Ollama    → no key, just OLLAMA_BASE_URL (ollama:llama3.1:8b)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
# Optional provider redundancy — comma-separated "provider:model" refs tried in
# order when the primary provider fails to open a stream. Empty = off (fail loud).
FORGE_LLM_FALLBACK_CHAIN=

# ── SPEDA Mark VI link (§7 wire contract, §9.2 graceful fallback) ────────────
# When present, the Gate connects to Mark VI's agents WebSocket as a peer and
# speaks its protocol (agent_register / task_dispatch / chat_request →
# task_result / chat_event). Same key Mark VI validates on every HTTP request.
SPEDA_API_KEY=
# Mark VI agents WS endpoint. agent_id in the path is set by the launched agent.
SPEDA_WS_URL=ws://127.0.0.1:8000/agents/ws/optimus

# ── Cell isolation (§8) ──────────────────────────────────────────────────────
# "docker"     — production default: one throwaway container per agent,
#                --network none, resource-capped, non-root (matches Mark VI's
#                own packages/sandbox posture).
# "subprocess" — reduced-isolation fallback for Docker-less dev/CI. Same
#                Cell contract; jailed to a per-agent workspace, wall-clock and
#                output capped. NOT a security boundary against hostile code.
# "auto"       — docker if the daemon is reachable, else subprocess (logged).
FORGE_CELL_BACKEND=auto
# Absolute path under which per-agent workspaces are created. One Cell per
# agent, never shared (§9.1).
FORGE_WORKSPACE_ROOT=./.forge/workspaces
# Docker image for DockerCell. Must have the agent's toolchain installed.
FORGE_CELL_IMAGE=python:3.12-slim

# ── Graphify sidecar (§5) ────────────────────────────────────────────────────
# Path to the `graphify` executable (pip package `graphifyy`). Blank → resolve
# from PATH. The graph is indexed once per session against the job's repo.
FORGE_GRAPHIFY_BIN=
